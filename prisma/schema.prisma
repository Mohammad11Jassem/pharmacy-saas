// ─────────────────────────────────────────────────────────────────────────────
// PRISMA SCHEMA
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum AccountType {
  ADMIN
  PHARMACY_OWNER
  MEDICAL_TEAM
  PHARMACY
}

enum UserAccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum PharmacyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum PharmacyDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DosageFormCategory {
  SOLID
  LIQUID
  SEMI_SOLID
  INJECTION
  OTHER
}

enum DrugSource {
  GENERAL
  PRIVATE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  RECEIVED
  CANCELLED
}

enum PurchaseOrderItemStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum BatchStatus {
  ACTIVE
  EXPIRED
  DEPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum SupplierInvoiceStatus {
  PENDING
  PARTIALLY_STOCKED
  STOCKED
  CANCELLED

  // PENDING
  // APPROVED
  // REJECTED

  /// should change to 
  //  DRAFT
  // POSTED
  // STOCKED
  // CANCELLED

  // DRAFT    => فاتورة مسجلة لكن لم تُفرد بعد
  // POSTED   => فاتورة مؤكدة ماليًا
  // STOCKED  => تم إدخال دفعاتها للمخزون
  // CANCELLED => ملغاة

  // ===>
  //   enum SupplierInvoiceStatus {
  //   PENDING
  //   PARTIALLY_STOCKED
  //   STOCKED
  //   CANCELLED
  // }

  // PENDING
  // => مسجلة لكن لم تُفرد على المخزون

  // PARTIALLY_STOCKED
  // => تم إدخال جزء من دفعاتها فقط

  // STOCKED
  // => تم إدخال كل دفعاتها إلى المخزون

  // CANCELLED
  // => ملغاة
}

enum CustomerRequestStatus {
  PENDING
  PARTIALLY_FULFILLED
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum CustomerRequestItemStatus {
  PENDING
  ORDERED
  RESERVED
  FULFILLED
  CANCELLED
}

enum PharmacyInvoiceType {
  SALE
  RETURN
  DAMAGE
}

enum PharmacyInvoiceStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SaleType {
  NORMAL
  CUSTOMER_REQUEST
}

enum UnitType {
  BOX
  STRIP
  TABLET
}

enum ReturnReason {
  CUSTOMER_CHANGED_MIND
  WRONG_ITEM
  DAMAGED
  EXPIRED
  OTHER
}

enum DamageReason {
  EXPIRED
  BROKEN
  DAMAGED_PACKAGING
  STORAGE_ISSUE
  CUSTOMER_RETURN_DAMAGED
  MANUAL_ADJUSTMENT
  OTHER
}

// ─── USER ACCOUNT ─────────────────────────────────────────────────────────────

model UserAccount {
  userId       Int               @id @default(autoincrement()) @map("user_id")
  email        String            @unique
  phone        String            @unique
  fullName     String            @map("full_name")
  passwordHash String?           @map("password_hash")
  accountType  AccountType       @map("account_type")
  status       UserAccountStatus @default(ACTIVE)
  loginCode    String            @unique @map("login_code")

  pharmacyOwner PharmacyOwner?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_accounts")
}

// ─── PHARMACY OWNER ───────────────────────────────────────────────────────────

model PharmacyOwner {
  pharmacyOwnerId Int @id @default(autoincrement()) @map("pharmacy_owner_id")

  userId Int         @unique @map("user_id")
  user   UserAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)

  nationalId String @unique @map("national_id")

  pharmacies Pharmacy[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pharmacy_owners")
}

// ─── PHARMACY ─────────────────────────────────────────────────────────────────

model Pharmacy {
  pharmacyId Int @id @default(autoincrement()) @map("pharmacy_id")

  pharmacyOwnerId Int           @map("pharmacy_owner_id")
  pharmacyOwner   PharmacyOwner @relation(fields: [pharmacyOwnerId], references: [pharmacyOwnerId], onDelete: Cascade)

  pharmacistLicenseNo String?        @unique @map("pharmacist_license_no")
  pharmacyName        String         @map("pharmacy_name")
  pharmacyCode        String?        @unique @map("pharmacy_code")
  contactPhone        String?        @map("contact_phone")
  email               String?        @unique
  governorate         String?
  healthDirectorate   String?        @map("health_directorate")
  areaName            String?        @map("area_name")
  addressText         String?        @map("address_text")
  status              PharmacyStatus @default(PENDING)
  openingDate         DateTime?      @map("opening_date") @db.Date

  credential PharmacyCredential?
  documents  PharmacyDocument[]

  pharmacyDrugs    PharmacyDrug[]
  suppliers        Supplier[]
  purchaseOrders   PurchaseOrder[]
  CustomerRequests CustomerRequest[]
  pharmacyInvoices PharmacyInvoice[]
  patients         Patient[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pharmacies")
}

// ─── PHARMACY CREDENTIAL ──────────────────────────────────────────────────────

model PharmacyCredential {
  pharmacyCredentialId Int @id @default(autoincrement()) @map("pharmacy_credential_id")

  pharmacyId Int      @unique @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  loginCode    String    @unique @map("login_code")
  passwordHash String?   @map("password_hash")
  lockedUntil  DateTime? @map("locked_until")
  activatedAt  DateTime? @map("activated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pharmacy_credentials")
}

// ─── PHARMACY DOCUMENT ────────────────────────────────────────────────────────

model PharmacyDocument {
  documentId Int @id @default(autoincrement()) @map("document_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  documentTypeId Int                  @map("document_type_id")
  documentType   PharmacyDocumentType @relation(fields: [documentTypeId], references: [documentTypeId])

  fileUrl String                 @map("file_url")
  notes   String?
  status  PharmacyDocumentStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pharmacy_documents")
}

// ─── PHARMACY DOCUMENT TYPE ───────────────────────────────────────────────────

model PharmacyDocumentType {
  documentTypeId Int @id @default(autoincrement()) @map("document_type_id")

  documentNameAr   String  @map("document_name_ar")
  issuingAuthority String? @map("issuing_authority")
  isRequired       Boolean @default(true) @map("is_required")

  documents PharmacyDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pharmacy_document_types")
}

// ─── DOSAGE FORM ──────────────────────────────────────────────────────────────

model DosageForm {
  dosageFormId   Int                @id @default(autoincrement()) @map("dosage_form_id")
  dosageFormName String             @unique @map("dosage_form_name")
  formCategory   DosageFormCategory @map("form_category")

  generalDrugs GeneralDrug[]
  privateDrugs PrivateDrug[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dosage_forms")
}

// ─── DRUG CATEGORY ────────────────────────────────────────────────────────────

model DrugCategory {
  categoryId   Int     @id @default(autoincrement()) @map("category_id")
  categoryName String  @unique @map("category_name")
  description  String? @db.Text

  drugAssignments                DrugCategoryAssignment[]
  privateDrugCategoryAssignments PrivateDrugCategoryAssignment[]
  createdAt                      DateTime                        @default(now()) @map("created_at")
  updatedAt                      DateTime                        @updatedAt @map("updated_at")

  @@map("drug_categories")
}

// ─── ACTIVE INGREDIENT ────────────────────────────────────────────────────────

model ActiveIngredient {
  ingredientId   Int     @id @default(autoincrement()) @map("ingredient_id")
  ingredientName String  @unique @map("ingredient_name")
  description    String? @db.Text

  drugIngredients        DrugIngredient[]
  privateDrugIngredients PrivateDrugIngredient[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("active_ingredients")
}

// ─── DRUG INGREDIENT ──────────────────────────────────────────────────────────

model DrugIngredient {
  drugIngredientId Int @id @default(autoincrement()) @map("drug_ingredient_id")

  ingredientId Int              @map("ingredient_id")
  ingredient   ActiveIngredient @relation(fields: [ingredientId], references: [ingredientId])

  generalDrugId Int         @map("general_drug_id")
  generalDrug   GeneralDrug @relation(fields: [generalDrugId], references: [generalDrugId], onDelete: Cascade)

  strengthValue Decimal @map("strength_value") @db.Decimal(12, 3)
  unit          String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([generalDrugId, ingredientId, unit])
  @@map("drug_ingredients")
}

model PrivateDrugIngredient {
  privateDrugIngredientId Int @id @default(autoincrement()) @map("private_drug_ingredient_id")

  privateDrugId Int @map("private_drug_id")
  ingredientId  Int @map("ingredient_id")

  strengthValue Decimal? @map("strength_value")
  unit          String?

  privateDrug PrivateDrug      @relation(fields: [privateDrugId], references: [privateDrugId], onDelete: Cascade)
  ingredient  ActiveIngredient @relation(fields: [ingredientId], references: [ingredientId])

  @@unique([privateDrugId, ingredientId])
  @@index([privateDrugId])
  @@index([ingredientId])
  @@map("private_drug_ingredients")
}

// ─── DRUG CATEGORY ASSIGNMENT ─────────────────────────────────────────────────

model DrugCategoryAssignment {
  uniqueId Int @id @default(autoincrement()) @map("unique_id")

  generalDrugId Int         @map("general_drug_id")
  generalDrug   GeneralDrug @relation(fields: [generalDrugId], references: [generalDrugId], onDelete: Cascade)

  categoryId Int          @map("category_id")
  category   DrugCategory @relation(fields: [categoryId], references: [categoryId])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([generalDrugId, categoryId])
  @@map("drug_category_assignments")
}

model PrivateDrugCategoryAssignment {
  uniqueId Int @id @default(autoincrement()) @map("unique_id")

  privateDrugId Int @map("private_drug_id")
  categoryId    Int @map("category_id")

  privateDrug PrivateDrug  @relation(fields: [privateDrugId], references: [privateDrugId], onDelete: Cascade)
  category    DrugCategory @relation(fields: [categoryId], references: [categoryId])

  @@unique([privateDrugId, categoryId])
  @@index([privateDrugId])
  @@index([categoryId])
  @@map("private_drug_category_assignments")
}

// ─── DRUG (SUPERTYPE) ─────────────────────────────────────────────────────────
model Drug {
  drugId Int        @id @default(autoincrement()) @map("drug_id")
  source DrugSource

  // exactly one of these will be populated
  generalDrug GeneralDrug?
  privateDrug PrivateDrug?

  pharmacyDrugs PharmacyDrug[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("drugs")
}

// ─── GENERAL DRUG ─────────────────────────────────────────────────────────────

model GeneralDrug {
  generalDrugId Int @id @default(autoincrement()) @map("general_drug_id")

  // 1-to-1 with Drug supertype
  drugId Int  @unique @map("drug_id")
  drug   Drug @relation(fields: [drugId], references: [drugId], onDelete: Cascade)

  dosageFormId Int        @map("dosage_form_id")
  dosageForm   DosageForm @relation(fields: [dosageFormId], references: [dosageFormId])

  tradeName     String  @map("trade_name")
  barcode       String  @unique
  unitsPerBox   Int     @map("units_per_box")
  netPrice      Decimal @map("net_price") @db.Decimal(12, 2)
  consumerPrice Decimal @map("consumer_price") @db.Decimal(12, 2)
  isRx          Boolean @default(false) @map("is_rx")
  isActive      Boolean @default(true) @map("is_active")

  ingredients DrugIngredient[]
  categories  DrugCategoryAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("general_drugs")
}

// ─── PRIVATE DRUG ─────────────────────────────────────────────────────────────

model PrivateDrug {
  privateDrugId Int @id @default(autoincrement()) @map("private_drug_id")

  // 1-to-1 with Drug supertype
  drugId Int  @unique @map("drug_id")
  drug   Drug @relation(fields: [drugId], references: [drugId], onDelete: Cascade)

  dosageFormId Int        @map("dosage_form_id")
  dosageForm   DosageForm @relation(fields: [dosageFormId], references: [dosageFormId])

  tradeName   String
  barcode     String  @unique
  unitsPerBox Int     @map("units_per_box")
  isRx        Boolean @default(false) @map("is_rx")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ingredients PrivateDrugIngredient[]
  categories  PrivateDrugCategoryAssignment[]

  @@map("private_drugs")
}

// ─── PHARMACY DRUG ────────────────────────────────────────────────────────────

model PharmacyDrug {
  pharmacyDrugId Int @id @default(autoincrement()) @map("pharmacy_drug_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  // Single FK to supertype — no more nullable columns
  drugId Int  @map("drug_id")
  drug   Drug @relation(fields: [drugId], references: [drugId])

  minStockAlert Int?    @map("min_stock_alert")
  sellPart      Boolean @default(false) @map("sell_part")

  netPrice      Decimal? @map("net_price") @db.Decimal(12, 2)
  consumerPrice Decimal? @map("consumer_price") @db.Decimal(12, 2)

  // expiryDateAlarm DateTime? @map("expiry_date_alarm") @db.Date
  expiryDateAlarm Int?    @default(60) @map("expiry_date_alarm")
  isActive        Boolean @default(true) @map("is_active")
  notes           String? @db.Text

  batches              Batch[]
  purchaseOrderItems   PurchaseOrderItem[]
  supplierInvoiceItems SupplierInvoiceItem[]
  drugLocations        DrugLocation[]
  CustomerRequestItems CustomerRequestItem[]
  saleInvoiceItems     SaleInvoiceItem[]
  returnInvoiceItems   ReturnInvoiceItem[]
  // damageInvoiceItems   DamageInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([pharmacyId, drugId]) // a pharmacy can't add the same drug twice
  @@map("pharmacy_drugs")
}

// ─── DRUG LOCATION ────────────────────────────────────────────────────────────

model DrugLocation {
  drugLocationId Int @id @default(autoincrement()) @map("drug_location_id")

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Cascade)

  storageLocation String @map("storage_location")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("drug_locations")
}

// ─── BATCH ────────────────────────────────────────────────────────────────────

model Batch {
  batchId Int @id @default(autoincrement()) @map("batch_id")

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Cascade)

  supplierInvoiceItemId Int?                 @map("supplier_invoice_item_id")
  supplierInvoiceItem   SupplierInvoiceItem? @relation(fields: [supplierInvoiceItemId], references: [supplierInvoiceItemId])

  expiryDate      DateTime?   @map("expiry_date") @db.Date
  initialQuantity Int         @map("initial_quantity")
  soldQuantity    Int         @default(0) @map("sold_quantity")
  receivedDate    DateTime?   @map("received_date") @db.Date
  status          BatchStatus @default(ACTIVE)

  saleInvoiceItemBatches SaleInvoiceItemBatch[]
  damageInvoiceItems     DamageInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pharmacyDrugId])
  @@index([supplierInvoiceItemId])
  @@map("batches")
}

// ─── SUPPLIER ─────────────────────────────────────────────────────────────────

model Supplier {
  supplierId Int @id @default(autoincrement()) @map("supplier_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  supplierName String  @map("supplier_name")
  phone        String?
  address      String?
  notes        String? @db.Text

  invoices SupplierInvoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

// ─── SUPPLIER INVOICE ─────────────────────────────────────────────────────────

model SupplierInvoice {
  supplierInvoiceId Int @id @default(autoincrement()) @map("supplier_invoice_id")

  supplierId Int      @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [supplierId], onDelete: Cascade)

  invoiceNumber String?               @unique @map("invoice_number")
  invoiceDate   DateTime              @map("invoice_date") @db.Date
  paymentStatus PaymentStatus         @default(PENDING) @map("payment_status")
  subtotal      Decimal               @db.Decimal(12, 2)
  discount      Decimal               @default(0) @db.Decimal(12, 2)
  totalPrice    Decimal               @map("total_price") @db.Decimal(12, 2)
  notes         String?               @db.Text
  status        SupplierInvoiceStatus @default(PENDING)

  items SupplierInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("supplier_invoices")
}

// ─── SUPPLIER INVOICE ITEM ────────────────────────────────────────────────────

model SupplierInvoiceItem {
  supplierInvoiceItemId Int @id @default(autoincrement()) @map("supplier_invoice_item_id")

  supplierInvoiceId Int             @map("supplier_invoice_id")
  supplierInvoice   SupplierInvoice @relation(fields: [supplierInvoiceId], references: [supplierInvoiceId], onDelete: Cascade)

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId])

  quantity     Int
  netUnitPrice Decimal @map("net_unit_price") @db.Decimal(12, 2)

  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  notes String? @db.Text

  batches Batch[]

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("supplier_invoice_items")
}

// ─── PURCHASE ORDER ───────────────────────────────────────────────────────────

model PurchaseOrder {
  purchaseOrderId Int @id @default(autoincrement()) @map("purchase_order_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [supplierId])

  orderDate   DateTime    @default(now()) @map("order_date") @db.Date
  orderStatus OrderStatus @default(PENDING) @map("order_status")
  notes       String?     @db.Text

  items PurchaseOrderItem[]

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("purchase_orders")
}

// ─── PURCHASE ORDER ITEM ──────────────────────────────────────────────────────

model PurchaseOrderItem {
  purchaseOrderItemId Int @id @default(autoincrement()) @map("purchase_order_item_id")

  purchaseOrderId Int           @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [purchaseOrderId], onDelete: Cascade)

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId])

  orderedQuantityBoxes Int                     @map("ordered_quantity_boxes")
  status               PurchaseOrderItemStatus @default(PENDING)
  notes                String?                 @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("purchase_order_items")
}

// ─── CUSTOMER REQUEST ─────────────────────────────────────────────────────────
model CustomerRequest {
  customerRequestId Int @id @default(autoincrement())

  pharmacyId Int
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId])

  customerName  String
  customerPhone String?
  notes         String?
  status        CustomerRequestStatus @default(PENDING)

  requestedAt DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CustomerRequestItem[]

  @@index([pharmacyId])
  @@index([status])
  @@index([customerPhone])
}

// ─── CUSTOMER REQUEST ITEM ─────────────────────────────────────────────────
model CustomerRequestItem {
  customerRequestItemId Int @id @default(autoincrement())

  customerRequestId Int
  customerRequest   CustomerRequest @relation(fields: [customerRequestId], references: [customerRequestId], onDelete: Cascade)

  pharmacyDrugId Int
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Restrict)

  requestedQuantity Int

  fulfilledQuantity Int @default(0)

  status CustomerRequestItemStatus @default(PENDING)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerRequestId])
  @@index([pharmacyDrugId])
  @@index([status])
}

// ───Patient───────────────────────────────────────────────────────────────────────────
model Patient {
  patientId Int @id @default(autoincrement()) @map("patient_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  fullName   String  @map("full_name")
  nationalId String? @map("national_id")
  phone      String?

  invoices PharmacyInvoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([pharmacyId, phone], name: "patient_pharmacy_phone_unique")
  @@unique([pharmacyId, nationalId], name: "patient_pharmacy_national_id_unique")
  @@index([pharmacyId])
  @@index([phone])
  @@map("patients")
}

// ─── PHARMACY INVOICE ─────────────────────────────────────────────────────────
model PharmacyInvoice {
  pharmacyInvoiceId Int @id @default(autoincrement()) @map("pharmacy_invoice_id")

  pharmacyId Int      @map("pharmacy_id")
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [pharmacyId], onDelete: Cascade)

  patientId Int?     @map("patient_id")
  patient   Patient? @relation(fields: [patientId], references: [patientId])

  invoiceType PharmacyInvoiceType   @map("invoice_type")
  invoiceDate DateTime              @default(now()) @map("invoice_date") @db.Date
  status      PharmacyInvoiceStatus @default(POSTED)

  notes String? @db.Text

  saleInvoice   SaleInvoice?
  returnInvoice ReturnInvoice?
  damageInvoice DamageInvoice?

  idempotencyKey String? @map("idempotency_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // @@unique([pharmacyId, idempotencyKey])
  @@unique([pharmacyId, invoiceType, idempotencyKey])
  @@index([pharmacyId])
  @@index([patientId])
  @@index([invoiceType])
  @@index([invoiceDate])
  @@map("pharmacy_invoices")
}

// ─── SALE INVOICE ─────────────────────────────────────────────────────────
model SaleInvoice {
  saleInvoiceId Int @id @default(autoincrement()) @map("sale_invoice_id")

  pharmacyInvoiceId Int             @unique @map("pharmacy_invoice_id")
  pharmacyInvoice   PharmacyInvoice @relation(fields: [pharmacyInvoiceId], references: [pharmacyInvoiceId], onDelete: Cascade)

  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  saleType      SaleType      @default(NORMAL) @map("sale_type")

  subtotal    Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)

  items   SaleInvoiceItem[]
  returns ReturnInvoice[]   @relation("SaleInvoiceReturns")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sale_invoices")
}

// ─── SALE INVOICE ITEM ─────────────────────────────────────────────────────────
model SaleInvoiceItem {
  saleInvoiceItemId Int @id @default(autoincrement()) @map("sale_invoice_item_id")

  saleInvoiceId Int         @map("sale_invoice_id")
  saleInvoice   SaleInvoice @relation(fields: [saleInvoiceId], references: [saleInvoiceId], onDelete: Cascade)

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Restrict)

  unitType         UnitType @map("unit_type")
  baseQuantity     Int      @map("base_quantity")
  unitFactorToBase Int      @map("unit_factor_to_base")

  baseUnitPrice   Decimal @map("base_unit_price") @db.Decimal(12, 2)
  extraPercentage Decimal @default(0) @map("extra_percentage") @db.Decimal(5, 2)
  finalUnitPrice  Decimal @map("final_unit_price") @db.Decimal(12, 2)
  totalPrice      Decimal @map("total_price") @db.Decimal(12, 2)

  batchAllocations SaleInvoiceItemBatch[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([saleInvoiceId])
  @@index([pharmacyDrugId])
  @@map("sale_invoice_items")
}

// ─── SALE INVOICE ITEM BATCH ─────────────────────────────────────────────────
model SaleInvoiceItemBatch {
  saleInvoiceItemBatchId Int @id @default(autoincrement()) @map("sale_invoice_item_batch_id")

  saleInvoiceItemId Int             @map("sale_invoice_item_id")
  saleInvoiceItem   SaleInvoiceItem @relation(fields: [saleInvoiceItemId], references: [saleInvoiceItemId], onDelete: Cascade)

  batchId Int   @map("batch_id")
  batch   Batch @relation(fields: [batchId], references: [batchId], onDelete: Restrict)

  // الكمية الخارجة من هذه الدفعة بالوحدة الأساسية
  baseQuantity Int @map("base_quantity")

  unitCostAtSale Decimal? @map("unit_cost_at_sale") @db.Decimal(12, 2)

  returnItems ReturnInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([saleInvoiceItemId])
  @@index([batchId])
  @@map("sale_invoice_item_batches")
}

// ─── RETURN INVOICE ─────────────────────────────────────────────────────────
model ReturnInvoice {
  returnInvoiceId Int @id @default(autoincrement()) @map("return_invoice_id")

  pharmacyInvoiceId Int             @unique @map("pharmacy_invoice_id")
  pharmacyInvoice   PharmacyInvoice @relation(fields: [pharmacyInvoiceId], references: [pharmacyInvoiceId], onDelete: Cascade)

  referenceSaleInvoiceId Int?         @map("reference_sale_invoice_id")
  referenceSaleInvoice   SaleInvoice? @relation("SaleInvoiceReturns", fields: [referenceSaleInvoiceId], references: [saleInvoiceId])

  subtotalRefund Decimal @default(0) @map("subtotal_refund") @db.Decimal(12, 2)

  items ReturnInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([referenceSaleInvoiceId])
  @@map("return_invoices")
}

// ─── RETURN INVOICE ITEM ─────────────────────────────────────────────────────
model ReturnInvoiceItem {
  returnInvoiceItemId Int @id @default(autoincrement()) @map("return_invoice_item_id")

  returnInvoiceId Int           @map("return_invoice_id")
  returnInvoice   ReturnInvoice @relation(fields: [returnInvoiceId], references: [returnInvoiceId], onDelete: Cascade)

  pharmacyDrugId Int          @map("pharmacy_drug_id")
  pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Restrict)

  saleInvoiceItemBatchId Int                  @map("sale_invoice_item_batch_id")
  saleInvoiceItemBatch   SaleInvoiceItemBatch @relation(fields: [saleInvoiceItemBatchId], references: [saleInvoiceItemBatchId], onDelete: Restrict)

  unitType         UnitType @map("unit_type")
  baseQuantity     Int      @map("base_quantity")
  unitFactorToBase Int      @map("unit_factor_to_base")

  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  returnReason       ReturnReason? @map("return_reason")
  restockToInventory Boolean       @default(true) @map("restock_to_inventory")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([returnInvoiceId])
  @@index([pharmacyDrugId])
  @@index([saleInvoiceItemBatchId])
  @@map("return_invoice_items")
}

// ─── DAMAGE INVOICE ─────────────────────────────────────────────────────────
model DamageInvoice {
  damageInvoiceId Int @id @default(autoincrement()) @map("damage_invoice_id")

  invoiceNumber String? @unique @map("invoice_number")
  damageReason String? @map("damage_reason") @db.Text
  pharmacyInvoiceId Int             @unique @map("pharmacy_invoice_id")
  pharmacyInvoice   PharmacyInvoice @relation(fields: [pharmacyInvoiceId], references: [pharmacyInvoiceId], onDelete: Cascade)

  items DamageInvoiceItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("damage_invoices")
}

// ── DAMAGE INVOICE ITEM ─────────────────────────────────────────────────
model DamageInvoiceItem {
  damageInvoiceItemId Int @id @default(autoincrement()) @map("damage_invoice_item_id")

  damageInvoiceId Int           @map("damage_invoice_id")
  damageInvoice   DamageInvoice @relation(fields: [damageInvoiceId], references: [damageInvoiceId], onDelete: Cascade)

  // pharmacyDrugId Int          @map("pharmacy_drug_id")
  // pharmacyDrug   PharmacyDrug @relation(fields: [pharmacyDrugId], references: [pharmacyDrugId], onDelete: Restrict)

  batchId Int   @map("batch_id")
  batch   Batch @relation(fields: [batchId], references: [batchId], onDelete: Restrict)

  // unitType         UnitType @map("unit_type")
  quantityDamaged Int @map("quantity_damaged")
  unitConsumerPrice Decimal? @map("unit_consumer_price") @db.Decimal(12, 2)

  // unitFactorToBase Int      @map("unit_factor_to_base")

  // damageReason DamageReason @map("damage_reason")
  notes        String?      @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([damageInvoiceId])
  // @@index([pharmacyDrugId])
  @@index([batchId])
  @@map("damage_invoice_items")
}
